{
  "name": "khurram-proteins",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.38",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:local": "wrangler d1 execute khurram-proteins-db --local --file=./migrations/0001_initial.sql && wrangler d1 execute khurram-proteins-db --local --file=./migrations/0002_seed.sql",
    "db:remote": "wrangler d1 execute khurram-proteins-db --remote --file=./migrations/0001_initial.sql && wrangler d1 execute khurram-proteins-db --remote --file=./migrations/0002_seed.sql",
    "hash:password": "bun run scripts/hash-password.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.454.0",
    "marked": "^14.1.3",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260409.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.1.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "workerd"
  ]
}
